<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h4 class="mb-0">Iniciar Sesión</h4>
                </div>
                <div class="card-body p-4">
                    <form id="loginForm">
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input name="email" type="email" class="form-control" placeholder="tucorreo@gmail.com" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Contraseña</label>
                            <input name="password" type="password" class="form-control" placeholder="••••••••" required>
                        </div>
                        <div id="error-msg" class="alert alert-danger d-none"></div>
                        <button type="submit" class="btn btn-dark w-100">Entrar</button>
                    </form>
                </div>
                <div class="card-footer text-center py-3 bg-light">
                    <small>¿No tenés cuenta? <a href="/register">Registrate aquí</a></small><br>
                    <small><a href="/forgot-password">¿Olvidaste tu contraseña?</a></small>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="/js/login.js"></script>
