<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h4 class="mb-0">Registro de Usuario</h4>
                </div>
                <div class="card-body p-4">
                    <form id="registerForm">
                        <div class="mb-3">
                            <label class="form-label">Nombre</label>
                            <input name="first_name" class="form-control" placeholder="Juan" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Apellido</label>
                            <input name="last_name" class="form-control" placeholder="Pérez" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input name="email" type="email" class="form-control" placeholder="tucorreo@gmail.com" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Edad</label>
                            <input name="age" type="number" class="form-control" placeholder="25" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Contraseña</label>
                            <input name="password" type="password" class="form-control" placeholder="••••••••" required>
                        </div>
                        <div id="error-msg" class="alert alert-danger d-none"></div>
                        <button type="submit" class="btn btn-dark w-100">Registrarse</button>
                    </form>
                </div>
                <div class="card-footer text-center py-3 bg-light">
                    <small>¿Ya tenés cuenta? <a href="/login">Iniciá sesión aquí</a></small>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="/js/register.js"></script>
