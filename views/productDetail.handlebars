<div class="container">
    <div class="row justify-content-center mt-4">
        <div class="col-md-6">
            <a href="/products" class="btn btn-outline-dark btn-sm mb-3">← Volver a productos</a>
            <div class="card shadow-sm">
                {{#if product.thumbnails.[0]}}
                    <img src="{{product.thumbnails.[0]}}" alt="{{product.title}}"
                         style="width:100%; height:280px; object-fit:cover; border-radius:4px 4px 0 0;">
                {{else}}
                    <img src="/images/product-placeholder.jpg" alt="Sin imagen" style="width:100%; height:280px; object-fit:cover; border-radius:4px 4px 0 0;">
                         style="width:100%; height:280px; object-fit:cover; border-radius:4px 4px 0 0;">
                {{/if}}
                <div class="card-body p-4">
                    <h3 class="fw-bold">{{product.title}}</h3>
                    <p class="text-muted">{{product.description}}</p>
                    <hr>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fs-4 fw-bold">${{product.price}}</span>
                        <span class="badge bg-secondary">{{product.category}}</span>
                    </div>
                    <p class="text-muted small">Stock disponible: {{product.stock}}</p>
                    <button onclick="addToCart('{{product._id}}')"
                            class="btn btn-dark w-100 mt-2">
                        🛒 Agregar al carrito
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
