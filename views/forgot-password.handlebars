<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h4 class="mb-0">Recuperar Contraseña</h4>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small mb-3">Ingresá tu email y te enviaremos un enlace para restablecer tu contraseña.</p>
                    <form id="forgotForm">
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input name="email" type="email" class="form-control" placeholder="tucorreo@gmail.com" required>
                        </div>
                        <div id="message" class="d-none alert"></div>
                        <button type="submit" class="btn btn-dark w-100">Enviar enlace</button>
                    </form>
                </div>
                <div class="card-footer text-center py-3 bg-light">
                    <small><a href="/login">← Volver al login</a></small>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
document.getElementById('forgotForm').addEventListener('submit', async e => {
    e.preventDefault();
    const email = e.target.email.value;
    const msgDiv = document.getElementById('message');
    try {
        const res = await fetch('/api/sessions/forgot-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
        });
        const data = await res.json();
        msgDiv.classList.remove('d-none', 'alert-success', 'alert-danger');
        msgDiv.classList.add(res.ok ? 'alert-success' : 'alert-danger');
        msgDiv.textContent = data.message || data.error;
    } catch (error) {
        msgDiv.classList.remove('d-none');
        msgDiv.classList.add('alert-danger');
        msgDiv.textContent = 'Error de conexión';
    }
});
</script>
