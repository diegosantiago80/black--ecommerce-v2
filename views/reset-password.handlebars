<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h4 class="mb-0">Nueva Contraseña</h4>
                </div>
                <div class="card-body p-4">
                    <div id="expired-msg" class="alert alert-danger d-none">
                        El enlace expiró. <a href="/forgot-password">Solicitá uno nuevo aquí</a>.
                    </div>
                    <form id="resetForm">
                        <div class="mb-3">
                            <label class="form-label">Nueva contraseña</label>
                            <input name="newPassword" type="password" class="form-control" placeholder="••••••••" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Confirmar contraseña</label>
                            <input name="confirmPassword" type="password" class="form-control" placeholder="••••••••" required>
                        </div>
                        <div id="message" class="d-none alert"></div>
                        <button type="submit" class="btn btn-dark w-100">Cambiar contraseña</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    const urlParams = new URLSearchParams(window.location.search);
    const token = urlParams.get('token');
    if (!token) {
        document.getElementById('resetForm').style.display = 'none';
        document.getElementById('expired-msg').classList.remove('d-none');
    }

    document.getElementById('resetForm').addEventListener('submit', async e => {
        e.preventDefault();
        const newPassword = e.target.newPassword.value;
        const confirmPassword = e.target.confirmPassword.value;
        const msgDiv = document.getElementById('message');

        if (newPassword !== confirmPassword) {
            msgDiv.classList.remove('d-none', 'alert-success', 'alert-danger');
            msgDiv.classList.add('alert-danger');
            msgDiv.textContent = 'Las contraseñas no coinciden';
            return;
        }
        try {
            const res = await fetch('/api/sessions/reset-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ token, newPassword }),
            });
            const data = await res.json();
            msgDiv.classList.remove('d-none', 'alert-success', 'alert-danger');
            if (res.ok) {
                msgDiv.classList.add('alert-success');
                msgDiv.textContent = '¡Contraseña actualizada! Redirigiendo...';
                document.getElementById('resetForm').style.display = 'none';
                setTimeout(() => window.location.replace('/login'), 2000);
            } else {
                msgDiv.classList.add('alert-danger');
                msgDiv.textContent = data.error;
                if (data.error.includes('expiró')) {
                    document.getElementById('resetForm').style.display = 'none';
                    document.getElementById('expired-msg').classList.remove('d-none');
                }
            }
        } catch (error) {
            msgDiv.classList.remove('d-none');
            msgDiv.classList.add('alert-danger');
            msgDiv.textContent = 'Error de conexión';
        }
    });
</script>
